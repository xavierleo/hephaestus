{
  "name": "hephaestus",
  "version": "1.4.12",
  "description": "Homelab stack scaffolder — Ninite for homelabs",
  "type": "module",
  "bin": {
    "hephaestus": "./dist/index.js"
  },
  "files": [
    "dist",
    "install.sh"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "preversion": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@inkjs/ui": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "fast-xml-parser": "^4.4.1",
    "fs-extra": "^11.2.0",
    "ini": "^4.1.3",
    "ink": "^4.4.1",
    "react": "^18.3.1",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/ini": "^4.1.1",
    "@types/react": "^18.3.3",
    "eslint": "^9.0.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
